{
  "openapi": "3.0.0",
  "info": {
    "title": "Attendance System API",
    "version": "1.0.0",
    "description": "REST API for the Attendance System. Most endpoints require a Bearer JWT token — use POST /api/auth/login to get one, then click the Authorize button at the top right and paste the token."
  },
  "servers": [
    { "url": "https://jamfortetech.com/verifyin-api", "description": "Production (cPanel)" },
    { "url": "http://localhost:5000", "description": "Local development" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["password"],
        "properties": {
          "username": { "type": "string", "example": "admin" },
          "email": { "type": "string", "example": "admin@company.com" },
          "password": { "type": "string", "example": "secret123" }
        }
      },
      "ForgotPasswordRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "example": "admin@company.com" }
        }
      },
      "ChangePasswordRequest": {
        "type": "object",
        "required": ["newPassword"],
        "properties": {
          "newPassword": { "type": "string", "example": "newSecret456" }
        }
      },
      "CompanyRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "example": "Acme Corp" },
          "address": { "type": "string", "example": "123 Main St, Lagos" },
          "latitude": { "type": "number", "example": 6.5244 },
          "longitude": { "type": "number", "example": 3.3792 },
          "radius_meters": { "type": "integer", "example": 100 },
          "default_shift_start": { "type": "string", "example": "08:00" },
          "default_shift_end": { "type": "string", "example": "17:00" }
        }
      },
      "CompanyLocationRequest": {
        "type": "object",
        "required": ["latitude", "longitude"],
        "properties": {
          "latitude": { "type": "number", "example": 6.5244 },
          "longitude": { "type": "number", "example": 3.3792 },
          "radius_meters": { "type": "integer", "example": 100 }
        }
      },
      "DepartmentRequest": {
        "type": "object",
        "required": ["name", "company_id"],
        "properties": {
          "name": { "type": "string", "example": "Engineering" },
          "company_id": { "type": "integer", "example": 1 }
        }
      },
      "DepartmentNameRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "example": "Engineering" }
        }
      },
      "UnitRequest": {
        "type": "object",
        "required": ["name", "department_id"],
        "properties": {
          "name": { "type": "string", "example": "Frontend Team" },
          "department_id": { "type": "integer", "example": 2 }
        }
      },
      "UnitUpdateRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "example": "Backend Team" }
        }
      },
      "EmployeeRequest": {
        "type": "object",
        "required": ["name", "company_id"],
        "properties": {
          "employee_id": { "type": "string", "example": "EMP-001" },
          "name": { "type": "string", "example": "Jane Doe" },
          "email": { "type": "string", "example": "jane@company.com" },
          "phone": { "type": "string", "example": "+2348012345678" },
          "company_id": { "type": "integer", "example": 1 },
          "department_id": { "type": "integer", "example": 2 },
          "unit_id": { "type": "integer", "example": 3 },
          "shift_start": { "type": "string", "example": "08:00" },
          "shift_end": { "type": "string", "example": "17:00" },
          "work_days": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"]
          }
        }
      },
      "AttendanceManualRequest": {
        "type": "object",
        "required": ["employee_id", "type"],
        "properties": {
          "employee_id": { "type": "integer", "example": 5 },
          "type": {
            "type": "string",
            "enum": ["clock_in", "clock_out"],
            "example": "clock_in"
          },
          "timestamp": { "type": "string", "format": "date-time", "example": "2026-06-08T08:00:00.000Z" },
          "notes": { "type": "string", "example": "Manual entry by admin" }
        }
      },
      "ScanRequest": {
        "type": "object",
        "required": ["employee_id"],
        "properties": {
          "employee_id": { "type": "integer", "example": 5 }
        }
      },
      "AdminAccountRequest": {
        "type": "object",
        "required": ["username", "company_ids"],
        "properties": {
          "username": { "type": "string", "example": "branchmanager" },
          "company_ids": {
            "type": "array",
            "items": { "type": "integer" },
            "example": [1, 2]
          }
        }
      },
      "SettingsUpdateRequest": {
        "type": "object",
        "properties": {
          "company_name": { "type": "string", "example": "Acme Corp" },
          "kiosk_greeting": { "type": "string", "example": "Welcome!" },
          "gps_auto_update": { "type": "boolean", "example": true }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["General"],
        "summary": "Health check",
        "responses": {
          "200": { "description": "Server is running" }
        }
      }
    },

    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login — returns a JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful — copy the token and use the Authorize button" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Send password reset email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ForgotPasswordRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Reset email sent" }
        }
      }
    },
    "/api/auth/register-face": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register employee face (one-time, requires employee JWT)",
        "description": "Send a base64 photo to store the employee's face embedding. Only works once — returns 409 if already registered. Call this after the employee changes their first-login password.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["image"],
                "properties": {
                  "image": {
                    "type": "string",
                    "description": "Base64-encoded image (data URI or raw base64)",
                    "example": "data:image/jpeg;base64,/9j/4AAQSkZJRgAB..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Face registered successfully" },
          "400": { "description": "No image provided" },
          "403": { "description": "Not an employee token" },
          "409": { "description": "Face already registered" },
          "503": { "description": "Face worker unreachable" }
        }
      }
    },
    "/api/auth/change-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Change password (requires auth)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChangePasswordRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Password changed" },
          "401": { "description": "Unauthorized" }
        }
      }
    },

    "/api/desk/companies": {
      "get": {
        "tags": ["Kiosk"],
        "summary": "List all companies (public)",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/desk/departments": {
      "get": {
        "tags": ["Kiosk"],
        "summary": "List departments by company (public)",
        "parameters": [
          { "name": "company_id", "in": "query", "required": false, "schema": { "type": "integer" }, "example": 1 }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/desk/units": {
      "get": {
        "tags": ["Kiosk"],
        "summary": "List units by department (public)",
        "parameters": [
          { "name": "department_id", "in": "query", "required": false, "schema": { "type": "integer" }, "example": 2 }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/desk/employees": {
      "get": {
        "tags": ["Kiosk"],
        "summary": "List employees (public)",
        "parameters": [
          { "name": "company_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "department_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "unit_id", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/desk/status/{employeeId}": {
      "get": {
        "tags": ["Kiosk"],
        "summary": "Get employee clock-in status (public)",
        "parameters": [
          { "name": "employeeId", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 5 }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/desk/insights/{employeeId}": {
      "get": {
        "tags": ["Kiosk"],
        "summary": "Get employee attendance insights (public)",
        "parameters": [
          { "name": "employeeId", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 5 },
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "enum": ["today", "week", "month", "custom"] },
            "example": "week"
          },
          { "name": "start", "in": "query", "schema": { "type": "string", "format": "date" }, "example": "2026-06-01" },
          { "name": "end", "in": "query", "schema": { "type": "string", "format": "date" }, "example": "2026-06-08" }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/desk/scan": {
      "post": {
        "tags": ["Kiosk"],
        "summary": "Clock in or out via kiosk scan (public)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ScanRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Scan recorded" }
        }
      }
    },

    "/api/companies": {
      "get": {
        "tags": ["Companies"],
        "summary": "List all companies",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "tags": ["Companies"],
        "summary": "Create a company",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompanyRequest" }
            }
          }
        },
        "responses": { "200": { "description": "Created" } }
      }
    },
    "/api/companies/{id}": {
      "get": {
        "tags": ["Companies"],
        "summary": "Get a company by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "put": {
        "tags": ["Companies"],
        "summary": "Update a company",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompanyRequest" }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Companies"],
        "summary": "Delete a company",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 }
        ],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/api/companies/{id}/location": {
      "patch": {
        "tags": ["Companies"],
        "summary": "Update GPS location / radius for a company",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompanyLocationRequest" }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      }
    },
    "/api/companies/{id}/logo": {
      "post": {
        "tags": ["Companies"],
        "summary": "Upload company logo (multipart form-data)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "logo": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Logo uploaded" } }
      }
    },
    "/api/companies/{id}/departments": {
      "get": {
        "tags": ["Companies"],
        "summary": "List departments for a company",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "tags": ["Companies"],
        "summary": "Create a department under a company",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DepartmentNameRequest" }
            }
          }
        },
        "responses": { "200": { "description": "Created" } }
      }
    },
    "/api/companies/{companyId}/departments/{deptId}": {
      "delete": {
        "tags": ["Companies"],
        "summary": "Delete a department from a company",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "companyId", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 },
          { "name": "deptId", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 3 }
        ],
        "responses": { "200": { "description": "Deleted" } }
      }
    },

    "/api/departments": {
      "get": {
        "tags": ["Departments"],
        "summary": "List departments (optionally filter by company)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "company_id", "in": "query", "schema": { "type": "integer" }, "example": 1 }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "tags": ["Departments"],
        "summary": "Create a department",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DepartmentRequest" }
            }
          }
        },
        "responses": { "200": { "description": "Created" } }
      }
    },
    "/api/departments/{id}": {
      "put": {
        "tags": ["Departments"],
        "summary": "Update a department",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 2 }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DepartmentRequest" }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Departments"],
        "summary": "Delete a department",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 2 }
        ],
        "responses": { "200": { "description": "Deleted" } }
      }
    },

    "/api/units": {
      "get": {
        "tags": ["Units"],
        "summary": "List units (optionally filter by department)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "department_id", "in": "query", "schema": { "type": "integer" }, "example": 2 }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "tags": ["Units"],
        "summary": "Create a unit",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UnitRequest" }
            }
          }
        },
        "responses": { "200": { "description": "Created" } }
      }
    },
    "/api/units/{id}": {
      "put": {
        "tags": ["Units"],
        "summary": "Update a unit",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 3 }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UnitUpdateRequest" }
            }
          }
        },
