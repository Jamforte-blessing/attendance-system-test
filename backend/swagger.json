    },
    "/api/employees/{id}/permanent": {
      "delete": {
        "tags": ["Employees"],
        "summary": "Permanently delete an employee (cannot be undone)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 5 }
        ],
        "responses": { "200": { "description": "Deleted permanently" } }
      }
    },

    "/api/attendance": {
      "get": {
        "tags": ["Attendance"],
        "summary": "List attendance logs with optional filters",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
